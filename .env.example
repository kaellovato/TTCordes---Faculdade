# Variáveis de Ambiente - Arquivo de Exemplo
# Copie este arquivo para .env e configure com seus valores

# Ambiente
NODE_ENV=development
PORT=3000

# MongoDB
MONGODB_URI=mongodb://localhost:27017/ttcordes
# Para MongoDB Atlas, use:
# MONGODB_URI=mongodb+srv://username:password@cluster0.qu3x1o7.mongodb.net/ttcordes?retryWrites=true&w=majority

# JWT
JWT_SECRET=seu-secret-super-secreto-aqui-mude-em-producao
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d
JWT_REFRESH_SECRET=seu-refresh-secret-aqui

# CORS (Futuro)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Logging
LOG_LEVEL=debug

# Session/Cookie (Futuro)
SESSION_SECRET=seu-session-secret

# Email (Futuro)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu-email@gmail.com
SMTP_PASS=sua-senha-app

# Database Backup (Futuro)
BACKUP_PATH=./backups

# Seed Database
SEED_DATABASE=true

